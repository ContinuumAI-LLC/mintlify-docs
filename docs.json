{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Continuum Lands",
  "seo": {
    "indexHiddenPages": false
  },
  "metadata": {
    "og:title": "Continuum Lands Docs",
    "og:description": "Documentación oficial de Continuum Lands — análisis inmobiliario con IA para inversionistas, desarrolladores y asesores en México.",
    "og:image": "/logo/logo-dark.svg"
  },
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Primeros Pasos",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentación",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo-dark.svg",
    "dark": "/logo/logo-light.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Soporte",
        "href": "mailto:soporte@continuumai.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Ir a la plataforma",
      "href": "https://lands.continuumai.app"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/continuumai",
      "linkedin": "https://linkedin.com/company/continuumai"
    }
  }
}